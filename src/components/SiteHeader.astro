---
import { NAV, SITE } from "@data/site";
---

<header class="sticky top-0 z-30 bg-paper-100/85 backdrop-blur-md border-b border-ink/8">
  <div class="container-site flex items-center justify-between h-16 lg:h-20">
    <a href="/" class="flex items-center gap-3 group" aria-label={`${SITE.name} home`}>
      <!-- Blueprint mark — minimal navy + bronze rule -->
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-sharp bg-ink text-paper-100 font-display text-lg font-medium">
        P
      </span>
      <span class="hidden sm:flex flex-col leading-tight">
        <span class="font-display text-base lg:text-lg font-medium text-ink">Practice Startup Services</span>
        <span class="phase-label text-graphite-600">The Independent Practice Blueprint</span>
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-7" aria-label="Primary">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class="text-small font-medium text-graphite-800 hover:text-ink transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a href="/journey" class="hidden md:inline-flex lg:hidden text-small font-medium text-graphite-800 hover:text-ink transition-colors">
        The Blueprint
      </a>
      <a href={SITE.scheduleUrl} class="btn-primary text-small whitespace-nowrap">
        <span class="hidden sm:inline">{SITE.primaryCta}</span>
        <span class="sm:hidden">Schedule</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</header>
