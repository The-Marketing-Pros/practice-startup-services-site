---
import { SITE } from "@data/site";

interface Props {
  variant?: "default" | "phase" | "service" | "specialty" | "state" | "resource";
  // Optional override pair when the variant rotation isn't right for a page
  eyebrow?: string;
  headline?: string;
  body?: string;
}

const { variant = "default", eyebrow, headline, body } = Astro.props;

// Variant rotation — each page family gets a different angle on the same offer.
// Defaults can be overridden per-page via the eyebrow/headline/body props.
const COPY: Record<string, { eyebrow: string; headline: string; body: string }> = {
  default: {
    eyebrow: "Ready to start?",
    headline: "Talk to the team before you pour the foundation wrong.",
    body: "One free consultation. Real answers. We'll tell you whether you need us — and if you don't, we'll tell you what to do anyway.",
  },
  phase: {
    eyebrow: "Stuck on this phase?",
    headline: "Get the order of operations right the first time.",
    body: "A free consultation surfaces the watchouts most likely to bite your specific situation. No script, no pitch — just the practical version of what we'd do in your seat.",
  },
  service: {
    eyebrow: "Want this crew?",
    headline: "Tell us what you're building. We'll quote a real number.",
    body: "We don't do 'contact for quote' theater. Bring your specialty and your timeline; we'll bring honest pricing and a realistic timeline on the first call.",
  },
  specialty: {
    eyebrow: "Specialty-specific advice?",
    headline: "Generic startup advice won't fit your specialty. Ours will.",
    body: "Bring your specialty, market, and target timing. We've launched enough of these to surface the watchouts most generic guidance misses.",
  },
  state: {
    eyebrow: "Timing varies by state.",
    headline: "Your state's specifics decide the launch sequence.",
    body: "Credentialing timing, payer mix, entity rules, and scope of practice all shift state to state. A consultation surfaces what changes for you specifically.",
  },
  resource: {
    eyebrow: "Beyond the resource?",
    headline: "When generic guidance hits its limits.",
    body: "Free resources are a starting point. When you want a real plan for your specific situation — specialty, state, target open date — the consultation is where that happens.",
  },
};

const copy = COPY[variant] ?? COPY.default;
const useEyebrow = eyebrow ?? copy.eyebrow;
const useHeadline = headline ?? copy.headline;
const useBody = body ?? copy.body;
---

<section class="bg-ink text-paper-100 py-24 lg:py-32 relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.06] -z-0 pointer-events-none" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="bp-grid-footer" x="0" y="0" width="48" height="48" patternUnits="userSpaceOnUse">
          <path d="M 48 0 L 0 0 0 48" fill="none" stroke="#F7F4EE" stroke-width="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#bp-grid-footer)" />
    </svg>
  </div>

  <div class="container-site relative">
    <div class="max-w-3xl mx-auto text-center">
      <div class="phase-label text-bronze-400 mb-6">{useEyebrow}</div>
      <h2 class="font-display text-display-xl font-medium text-paper-100 mb-6 text-balance">
        {useHeadline}
      </h2>
      <p class="text-lede text-paper-200/85 max-w-narrow mx-auto mb-8 text-pretty">
        {useBody}
      </p>
      <a href={SITE.scheduleUrl} class="btn-primary text-base">
        {SITE.primaryCta}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>
