---
// Long-form editorial deep-dive for select phases.
// Renders only when src/data/phase-deep-dives.ts has content for the phase.
import type { PhaseId } from "@data/phases";
import { getDeepDive } from "@data/phase-deep-dives";
import { SITE, ARCHITECT } from "@data/site";

const architectVisible =
  ARCHITECT.enabled &&
  ARCHITECT.appUrl &&
  !ARCHITECT.appUrl.includes("{{") &&
  ARCHITECT.publicKey &&
  !ARCHITECT.publicKey.includes("{{");

interface Props {
  phaseId: PhaseId;
}

const { phaseId } = Astro.props;
const dd = getDeepDive(phaseId);
---

{
  dd && (
    <section class="border-b border-ink/8 py-16 lg:py-24 bg-paper-100">
      <div class="container-site">
        <div class="max-w-prose mx-auto">
          <div class="phase-label text-bronze-700 mb-4">Editorial · the deep dive</div>
          <p class="text-lede text-graphite-800 leading-relaxed mb-10 text-pretty">
            {dd.intro}
          </p>

          {dd.sections.map((s) => {
            // Pure pull-quote section (no heading or body) renders an editorial break
            if (s.pullQuote && !s.heading && !s.body) {
              return (
                <figure class="my-14 pl-6 border-l-2 border-bronze">
                  <blockquote class="font-display text-display-md font-medium text-ink leading-tight text-balance">
                    “{s.pullQuote}”
                  </blockquote>
                </figure>
              );
            }
            return (
              <div class="mb-10">
                <h2 class="font-display text-display-md font-medium text-ink mb-4 text-balance">
                  {s.heading}
                </h2>
                {s.body.split(/\n\n+/).map((p) => (
                  <p class="text-body text-graphite-800 leading-relaxed mb-4 text-pretty">{p}</p>
                ))}
                {s.numericCallout && (
                  <div class="mt-6 inline-flex items-center gap-4 border border-bronze/40 bg-bronze/[0.08] rounded-sharp px-5 py-3">
                    <div class="font-mono">
                      <div class="text-label uppercase tracking-[0.18em] text-bronze-700">
                        {s.numericCallout.label}
                      </div>
                      <div class="text-display-md text-ink font-medium leading-none mt-1">
                        {s.numericCallout.value}
                      </div>
                    </div>
                    {s.numericCallout.sub && (
                      <div class="text-small text-graphite-700 max-w-[14ch]">{s.numericCallout.sub}</div>
                    )}
                  </div>
                )}
                {s.comparisonGrid && (
                  <div class="mt-8 -mx-2 sm:mx-0">
                    <div class="phase-label text-bronze-700 mb-3 ml-2 sm:ml-0">
                      {s.comparisonGrid.columnLabel} · at a glance
                    </div>
                    <div class="divide-y divide-ink/10 border-t-2 border-b-2 border-ink/15">
                      {s.comparisonGrid.rows.map((row) => (
                        <div class="grid grid-cols-12 gap-4 py-4 px-2 sm:px-0 hover:bg-paper-200/40 transition-colors">
                          <div class="col-span-12 sm:col-span-3">
                            <div class="font-mono text-label uppercase tracking-[0.18em] text-bronze-700">
                              {row.name}
                            </div>
                          </div>
                          <div class="col-span-12 sm:col-span-3">
                            <div class="font-display text-base font-medium text-ink leading-tight">
                              {row.lead}
                            </div>
                          </div>
                          <div class="col-span-12 sm:col-span-6 text-small text-graphite-700 leading-relaxed text-pretty">
                            {row.detail}
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            );
          })}

          {dd.faq && dd.faq.length > 0 && (
            <div class="mt-16 pt-10 border-t border-ink/8">
              <div class="phase-label text-bronze-700 mb-4">Common questions</div>
              <h2 class="font-display text-display-md font-medium text-ink mb-8 text-balance">
                What people ask most.
              </h2>
              <ol class="divide-y divide-ink/12 border-t-2 border-b-2 border-ink/15 list-none" role="list">
                {dd.faq.map((item, idx) => (
                  <li class="py-6 md:py-8 grid grid-cols-12 gap-3 md:gap-6">
                    <div class="col-span-12 md:col-span-2">
                      <!-- Mobile: small inline counter (Q#) so the question dominates. Desktop: large display numeral -->
                      <div class="hidden md:block font-mono text-display-md text-bronze-700 font-medium leading-none">
                        {String(idx + 1).padStart(2, "0")}
                      </div>
                      <div class="hidden md:block phase-label text-graphite-500 mt-2">Question</div>
                      <div class="md:hidden flex items-baseline gap-2">
                        <span class="font-mono text-label uppercase tracking-[0.18em] text-bronze-700">
                          Q{String(idx + 1).padStart(2, "0")}
                        </span>
                      </div>
                    </div>
                    <div class="col-span-12 md:col-span-10">
                      <h3 class="font-display text-display-sm font-medium text-ink mb-3 text-balance">
                        {item.q}
                      </h3>
                      <p class="text-body text-graphite-800 leading-relaxed text-pretty max-w-prose">
                        {item.a}
                      </p>
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          )}

          <div class="mt-14 pt-10 border-t border-ink/8 flex flex-wrap gap-3">
            <a href={SITE.scheduleUrl} class="btn-primary">
              {SITE.primaryCta}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            {architectVisible && (
              <button type="button" data-architect-open class="btn-secondary">
                Ask The Architect
              </button>
            )}
          </div>
        </div>
      </div>
    </section>
  )
}
