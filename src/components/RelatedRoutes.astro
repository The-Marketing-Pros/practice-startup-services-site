---
// Related routes block — compact footer-adjacent links to the specialty + state hubs.
// Previously a giant two-column section enumerating all 13 specialties + 15 states; that ate
// 40%+ of scroll on every page and made the site read as template-y. Now a thin module.
---

<section class="border-b border-ink/8 py-10 lg:py-12 bg-paper-200/30">
  <div class="container-site">
    <div class="grid sm:grid-cols-2 gap-6 max-w-prose-wide">
      <a
        href="/specialty/"
        class="group flex items-start justify-between gap-4 -mx-3 px-3 py-2 rounded-soft hover:bg-paper-100 transition-colors"
      >
        <div>
          <div class="phase-label text-bronze-700 mb-1">By specialty</div>
          <div class="font-display text-display-sm font-medium text-ink mb-1">
            See how this changes for your specialty.
          </div>
          <p class="text-small text-graphite-700">
            13 specialty-specific guides covering capital range, payer mix, and watchouts.
          </p>
        </div>
        <svg
          width="20"
          height="20"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true"
          class="text-graphite-600 group-hover:text-ink group-hover:translate-x-0.5 transition-all flex-shrink-0 mt-1"
        >
          <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>

      <a
        href="/states/"
        class="group flex items-start justify-between gap-4 -mx-3 px-3 py-2 rounded-soft hover:bg-paper-100 transition-colors"
      >
        <div>
          <div class="phase-label text-bronze-700 mb-1">By state</div>
          <div class="font-display text-display-sm font-medium text-ink mb-1">
            See how this changes in your state.
          </div>
          <p class="text-small text-graphite-700">
            15 state guides covering credentialing timing, payer landscape, and entity rules.
          </p>
        </div>
        <svg
          width="20"
          height="20"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true"
          class="text-graphite-600 group-hover:text-ink group-hover:translate-x-0.5 transition-all flex-shrink-0 mt-1"
        >
          <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>
