---
// Related routes block — cross-links to specialty and state hubs from any phase or service page.
// Increases internal link density for SEO + visitor navigation.
import { specialties } from "@data/specialties";
import { states } from "@data/states";
---

<section class="border-b border-ink/8 py-16 lg:py-20 bg-paper-200/40">
  <div class="container-site">
    <div class="grid lg:grid-cols-2 gap-10">
      <div>
        <div class="phase-label text-bronze-700 mb-3">How this changes by specialty</div>
        <h2 class="font-display text-display-md font-medium text-ink mb-4 text-balance">
          Specialty-specific launch guidance.
        </h2>
        <p class="text-body text-graphite-800 leading-relaxed mb-6 text-pretty">
          The 7-phase blueprint applies in every specialty, but capital requirements, payer mix,
          and credentialing nuances shift. Pick yours for the version that fits.
        </p>
        <ul class="grid sm:grid-cols-2 gap-2">
          {
            specialties.map((s) => (
              <li>
                <a
                  href={`/specialty/${s.slug}`}
                  class="block py-2 px-3 -mx-3 rounded-soft text-small text-graphite-800 hover:text-ink hover:bg-paper-100 transition-colors"
                >
                  <span class="font-mono text-bronze-700 mr-2">›</span>
                  {s.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <div class="phase-label text-bronze-700 mb-3">How this changes by state</div>
        <h2 class="font-display text-display-md font-medium text-ink mb-4 text-balance">
          State-specific launch guidance.
        </h2>
        <p class="text-body text-graphite-800 leading-relaxed mb-6 text-pretty">
          Credentialing timing, payer mix, entity rules, and scope of practice all shift state to
          state. Find yours for the version that fits.
        </p>
        <ul class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          {
            states.map((s) => (
              <li>
                <a
                  href={`/states/${s.slug}`}
                  class="block py-2 px-3 -mx-3 rounded-soft text-small text-graphite-800 hover:text-ink hover:bg-paper-100 transition-colors"
                >
                  <span class="font-mono text-bronze-700 mr-2">{s.abbr}</span>
                  {s.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
