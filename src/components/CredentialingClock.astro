---
// Control Room moment #3 — Credentialing Clock visual for Phase 4
// 03b §1 Layer 3: "credentialing failure is the most expensive startup mistake"
// Restrained Control Room aesthetic: dark slate + signal teal + crisp numeric typography
---

<section class="bg-ink text-paper-100 py-16 lg:py-24 relative overflow-hidden border-t border-paper-200/10">
  <!-- Faint blueprint grid + signal glow — instrument panel mood, not pretty card grid -->
  <div class="absolute inset-0 opacity-[0.04] -z-0 pointer-events-none" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="clock-grid" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <path d="M 32 0 L 0 0 0 32" fill="none" stroke="hsl(var(--paper-100))" stroke-width="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#clock-grid)" />
    </svg>
  </div>
  <div class="absolute inset-0 opacity-25 -z-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-32 -right-32 h-96 w-96 rounded-full bg-signal/12 blur-3xl"></div>
  </div>

  <div class="container-site relative">
    <div class="flex items-start justify-between flex-wrap gap-6 mb-10 lg:mb-14">
      <div class="max-w-prose-wide">
        <div class="phase-label text-signal mb-3">
          <span class="inline-flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-signal animate-pulse"></span>
            Control room · Credentialing clock
          </span>
        </div>
        <h2 class="font-display text-display-lg font-medium text-paper-100 mb-4 text-balance">
          The 90–180 day credentialing window.
        </h2>
        <p class="text-lede text-paper-200/85 text-pretty">
          Every payer has a clock. They start when your application is complete (not when you submit it).
          Start late, and you launch a practice that can't bill the payers you need.
        </p>
      </div>

      <!-- Live system status badge — reads as an instrument, not a CTA -->
      <div class="shrink-0 border border-bronze/40 bg-bronze/[0.08] rounded-sharp px-4 py-3 font-mono">
        <div class="text-label uppercase tracking-[0.18em] text-bronze-300 mb-1">Start prep at</div>
        <div class="text-display-md font-medium text-paper-100 leading-none">T−180</div>
        <div class="text-small text-paper-200/70 mt-1">days before open</div>
      </div>
    </div>

    <!-- The instrument: horizontal timeline rail with payer plot rows -->
    <div class="relative mb-12">
      <!-- Axis with tick marks + dropdown gridlines through the plot area, visible md+ -->
      <div class="hidden md:block">
        <div class="grid grid-cols-12 gap-4">
          <div class="col-span-3"></div>
          <div class="col-span-7 relative">
            <!-- Solid axis baseline rule -->
            <div class="relative h-px bg-paper-200/60">
              {["T−180", "T−150", "T−120", "T−60", "OPEN"].map((label, i, arr) => (
                <div
                  class="absolute top-0 flex flex-col items-center"
                  style={`left: ${(i / (arr.length - 1)) * 100}%; transform: translate(-50%, 0);`}
                >
                  <div class={`h-4 w-px ${i === arr.length - 1 ? "bg-bronze" : "bg-paper-200/85"}`}></div>
                  <div class={`font-mono text-label tracking-[0.18em] uppercase mt-2 ${i === arr.length - 1 ? "text-bronze font-medium" : "text-paper-200/80"}`}>
                    {label}
                  </div>
                </div>
              ))}
            </div>

          </div>
          <div class="col-span-2"></div>
        </div>
      </div>

      <!-- Continuation gridlines spanning the entire payer plot area, visible md+, so each tick tracks down through all 3 rows -->
      <div class="hidden md:block relative">
        <div class="grid grid-cols-12 gap-4 relative">
          <div class="col-span-3"></div>
          <div class="col-span-7 relative h-0">
            <!-- Tall continuation lines absolute-positioned to span all 3 plot rows -->
            <div class="absolute top-0 left-0 right-0 pointer-events-none" style="height: 14rem;">
              {[0, 25, 50, 75, 100].map((pct) => (
                <div
                  class={`absolute top-0 w-px ${pct === 100 ? "bg-bronze/35" : "bg-paper-200/15"}`}
                  style={`left: ${pct}%; height: 100%;`}
                ></div>
              ))}
            </div>
          </div>
          <div class="col-span-2"></div>
        </div>
      </div>

      <!-- Payer plot rows — each row plots its window as a visible segment, with gridlines from the axis ticks running through -->
      <div class="space-y-3 mt-6 md:mt-4 relative z-10">
        <!-- Medicare 45-90 days from complete app: roughly the second half of the prep window -->
        <div class="grid grid-cols-12 items-center gap-4">
          <div class="col-span-12 md:col-span-3">
            <div class="phase-label text-signal">Medicare</div>
            <div class="text-small text-paper-200/70 mt-0.5">CMS-855 acceptance</div>
          </div>
          <div class="col-span-12 md:col-span-7">
            <div class="relative h-9 bg-paper-200/[0.04] rounded-sharp border border-paper-200/15">
              <!-- Vertical gridlines aligned to axis ticks (md+ only) -->
              <div class="hidden md:block absolute inset-y-0 left-0 right-0 pointer-events-none">
                {[0, 25, 50, 75].map((pct) => (
                  <div class="absolute top-0 bottom-0 w-px bg-paper-200/15" style={`left: ${pct}%;`}></div>
                ))}
                <div class="absolute top-0 bottom-0 w-px bg-bronze/60" style="left: 100%;"></div>
              </div>
              <!-- Plot segment: 45-90 days = right half of the 180-day window -->
              <div class="absolute top-0 bottom-0 bg-signal/40 border-l-2 border-r-2 border-signal rounded-sharp" style="left: 50%; right: 12.5%;"></div>
              <div class="absolute inset-y-0 left-0 right-0 flex items-center px-3 z-10">
                <span class="font-mono text-base text-paper-100 font-medium leading-none">45–90 days</span>
              </div>
            </div>
          </div>
          <div class="col-span-12 md:col-span-2 font-mono text-label text-left md:text-right uppercase tracking-[0.18em] text-signal">FAST</div>
        </div>

        <div class="grid grid-cols-12 items-center gap-4">
          <div class="col-span-12 md:col-span-3">
            <div class="phase-label text-signal">Medicaid</div>
            <div class="text-small text-paper-200/70 mt-0.5">State-specific</div>
          </div>
          <div class="col-span-12 md:col-span-7">
            <div class="relative h-9 bg-paper-200/[0.04] rounded-sharp border border-paper-200/15">
              <div class="hidden md:block absolute inset-y-0 left-0 right-0 pointer-events-none">
                {[0, 25, 50, 75].map((pct) => (
                  <div class="absolute top-0 bottom-0 w-px bg-paper-200/15" style={`left: ${pct}%;`}></div>
                ))}
                <div class="absolute top-0 bottom-0 w-px bg-bronze/60" style="left: 100%;"></div>
              </div>
              <div class="absolute top-0 bottom-0 bg-signal/40 border-l-2 border-r-2 border-signal rounded-sharp" style="left: 33.33%; right: 16.67%;"></div>
              <div class="absolute inset-y-0 left-0 right-0 flex items-center px-3 z-10">
                <span class="font-mono text-base text-paper-100 font-medium leading-none">60–120 days</span>
              </div>
            </div>
          </div>
          <div class="col-span-12 md:col-span-2 font-mono text-label text-left md:text-right uppercase tracking-[0.18em] text-paper-200/70">VARIABLE</div>
        </div>

        <div class="grid grid-cols-12 items-center gap-4">
          <div class="col-span-12 md:col-span-3">
            <div class="phase-label text-bronze-300">Commercial</div>
            <div class="text-small text-paper-200/70 mt-0.5">BCBS, UHC, Aetna, Cigna</div>
          </div>
          <div class="col-span-12 md:col-span-7">
            <div class="relative h-9 bg-paper-200/[0.04] rounded-sharp border border-paper-200/15">
              <div class="hidden md:block absolute inset-y-0 left-0 right-0 pointer-events-none">
                {[0, 25, 50, 75].map((pct) => (
                  <div class="absolute top-0 bottom-0 w-px bg-paper-200/15" style={`left: ${pct}%;`}></div>
                ))}
                <div class="absolute top-0 bottom-0 w-px bg-bronze/60" style="left: 100%;"></div>
              </div>
              <div class="absolute top-0 bottom-0 bg-bronze/40 border-l-2 border-r-2 border-bronze rounded-sharp" style="left: 0%; right: 16.67%;"></div>
              <div class="absolute inset-y-0 left-0 right-0 flex items-center px-3 z-10">
                <span class="font-mono text-base text-paper-100 font-medium leading-none">90–180 days</span>
              </div>
            </div>
          </div>
          <div class="col-span-12 md:col-span-2 font-mono text-label text-left md:text-right uppercase tracking-[0.18em] text-bronze">CRITICAL</div>
        </div>
      </div>
    </div>

    <!-- Sequence rail — numbered steps along the same conceptual timeline -->
    <div>
      <div class="phase-label text-signal mb-5">Sequence · from target open date</div>
      <ol class="grid grid-cols-1 md:grid-cols-4 gap-0 md:gap-px md:bg-paper-200/15 border border-paper-200/15 rounded-sharp overflow-hidden">
        <li class="bg-ink p-5 lg:p-6">
          <div class="font-mono text-label text-bronze-300 tracking-[0.18em] uppercase mb-2">T−180 to T−150</div>
          <div class="font-display text-base font-medium text-paper-100 mb-2">CAQH + license verification</div>
          <p class="text-small text-paper-200/75 leading-relaxed">All providers fully CAQH-attested. State medical licenses verified. NPI active.</p>
        </li>
        <li class="bg-ink p-5 lg:p-6">
          <div class="font-mono text-label text-bronze-300 tracking-[0.18em] uppercase mb-2">T−150 to T−120</div>
          <div class="font-display text-base font-medium text-paper-100 mb-2">Medicare + Medicaid submitted</div>
          <p class="text-small text-paper-200/75 leading-relaxed">CMS-855I/B for each provider. State Medicaid enrollment per program rules.</p>
        </li>
        <li class="bg-ink p-5 lg:p-6">
          <div class="font-mono text-label text-bronze-300 tracking-[0.18em] uppercase mb-2">T−120 to T−60</div>
          <div class="font-display text-base font-medium text-paper-100 mb-2">Commercial applications submitted</div>
          <p class="text-small text-paper-200/75 leading-relaxed">Tier 1 commercial payers in your market. Follow up every 2 weeks. Track effective dates.</p>
        </li>
        <li class="bg-ink p-5 lg:p-6">
          <div class="font-mono text-label text-bronze-300 tracking-[0.18em] uppercase mb-2">T−60 to launch</div>
          <div class="font-display text-base font-medium text-paper-100 mb-2">Verify + activate</div>
          <p class="text-small text-paper-200/75 leading-relaxed">Confirm effective dates. Update billing system. Test claims for each payer before go-live.</p>
        </li>
      </ol>
    </div>

    <div class="mt-8 font-mono text-label uppercase tracking-[0.18em] text-paper-200/50">
      Estimates based on typical timelines · specialty, state, and payer mix can extend any window
    </div>
  </div>
</section>
