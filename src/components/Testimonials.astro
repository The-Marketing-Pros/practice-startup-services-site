---
// Client testimonials — renders nothing until real, permissioned testimonials
// exist in src/data/testimonials.ts with status "published". See the integrity
// gate documented in that file.
import { publishedTestimonials } from "@data/testimonials";
---

{
  publishedTestimonials.length > 0 && (
    <section class="border-b border-ink/8 py-20 lg:py-28" aria-labelledby="testimonials-heading">
      <div class="container-site">
        <div class="max-w-3xl mb-12 reveal">
          <div class="phase-label text-bronze-700 mb-4">From the founders we've launched</div>
          <h2 id="testimonials-heading" class="font-display text-display-lg font-medium text-ink text-balance">
            In their words.
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          {publishedTestimonials.map((t, i) => (
            <figure class={`card-blueprint flex flex-col reveal ${i % 2 === 1 ? "reveal-delay-1" : ""}`}>
              <blockquote class="font-display text-display-sm font-medium text-ink leading-snug text-balance mb-5">
                “{t.quote}”
              </blockquote>
              <figcaption class="mt-auto pt-4 border-t border-ink/8">
                <div class="text-small font-medium text-ink">{t.attribution}</div>
                {t.context && <div class="phase-label text-graphite-600 mt-1">{t.context}</div>}
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )
}
