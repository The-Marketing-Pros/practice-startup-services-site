---
// CONTROL ROOM MOMENT #1 — Launch Readiness Scan
// 03b §1 Layer 3 — homepage scan. Static UX in v1, interactive routing in v2.
import { SITE } from "@data/site";
---

<section class="border-b border-ink/8 bg-ink text-paper-100 relative overflow-hidden">
  <!-- Subtle "control room" signature: signal-teal sparkle, restrained -->
  <div class="absolute inset-0 -z-0 opacity-30 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-32 -right-32 h-96 w-96 rounded-full bg-signal/10 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-bronze/10 blur-3xl"></div>
  </div>

  <div class="container-site relative py-16 lg:py-20">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <div class="phase-label text-signal mb-4">Launch readiness scan</div>
        <h2 class="font-display text-display-lg text-paper-100 font-medium mb-5 text-balance">
          Where are you in the launch?
        </h2>
        <p class="text-lede text-paper-200/80 max-w-narrow mb-6">
          Five questions. We'll route you to the exact phase, the resources you need now,
          and the next decision in front of you.
        </p>
        <p class="text-small text-paper-200/60 font-mono">
          No signup. No spam. Just sequencing.
        </p>
      </div>

      <div class="lg:col-span-7">
        <form
          class="bg-paper-100 text-ink rounded-card p-6 lg:p-8 shadow-elevated"
          action={SITE.scheduleUrl}
          method="get"
        >
          <fieldset class="space-y-6">
            <legend class="phase-label text-bronze-700 mb-2">Scan</legend>

            <div>
              <label class="block text-small font-medium text-ink mb-2" for="scan-role">
                I'm a…
              </label>
              <select
                id="scan-role"
                name="role"
                class="w-full bg-paper-50 border border-ink/15 rounded-soft px-4 py-3 text-body focus:border-bronze focus:outline-none"
              >
                <option value="">Choose your role</option>
                <option value="md">Physician (MD/DO)</option>
                <option value="np">Nurse Practitioner</option>
                <option value="pa">Physician Assistant</option>
                <option value="bh">Behavioral Health Provider</option>
                <option value="admin">Practice Administrator</option>
              </select>
            </div>

            <div>
              <label class="block text-small font-medium text-ink mb-2" for="scan-stage">
                Where am I in the journey?
              </label>
              <select
                id="scan-stage"
                name="stage"
                class="w-full bg-paper-50 border border-ink/15 rounded-soft px-4 py-3 text-body focus:border-bronze focus:outline-none"
              >
                <option value="">Pick the closest match</option>
                <option value="thinking">Thinking about it</option>
                <option value="planning">Planning</option>
                <option value="forming">Forming the business</option>
                <option value="credentialing">In credentialing</option>
                <option value="building">Building infrastructure</option>
                <option value="launching">Launching marketing</option>
                <option value="open">Open and growing</option>
              </select>
            </div>

            <div>
              <label class="block text-small font-medium text-ink mb-2" for="scan-timeline">
                Target open date
              </label>
              <select
                id="scan-timeline"
                name="timeline"
                class="w-full bg-paper-50 border border-ink/15 rounded-soft px-4 py-3 text-body focus:border-bronze focus:outline-none"
              >
                <option value="">Choose a window</option>
                <option value="3mo">Within 3 months</option>
                <option value="6mo">3–6 months</option>
                <option value="9mo">6–9 months</option>
                <option value="12mo">9–12 months</option>
                <option value="exploring">Just exploring</option>
              </select>
            </div>

            <button type="submit" class="btn-primary w-full justify-center">
              Get my next steps
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>

            <p class="text-small text-graphite-600 text-center">
              Routes you to the matching phase guide + a consultation slot.
            </p>
          </fieldset>
        </form>
      </div>
    </div>
  </div>
</section>
