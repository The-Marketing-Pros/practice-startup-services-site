---
// The Architect — AI companion embed.
//
// Replaced 2026-06-11 ~07:00 EDT: the prior custom implementation
// (Astro drawer + vanilla JS controller + CF Pages Function calling Anthropic Haiku)
// is gone. We now load the embeddable widget from the prompt-platform CRM
// (PR #261, /embed/chat.js).
//
// Benefits:
// - CRM owns the agent + system prompt + token budget + Turnstile + origin lock.
// - A4 chat-to-CRM lead handoff lands automatically when the platform ships it.
// - One <script> tag instead of ~700 LOC of custom drawer + endpoint code.
// - No ANTHROPIC_API_KEY secret on this site.
//
// Wiring: see src/data/site.ts (ARCHITECT block) and
// personas/alf/campaigns/2026-Q2/practice-startup-services/06a-the-architect-system-prompt.md.
import { ARCHITECT } from "@data/site";

const enabled =
  ARCHITECT.enabled &&
  ARCHITECT.appUrl &&
  !ARCHITECT.appUrl.includes("{{") &&
  ARCHITECT.publicKey &&
  !ARCHITECT.publicKey.includes("{{");

const embedSrc = enabled ? `${ARCHITECT.appUrl.replace(/\/$/, "")}/embed/chat.js` : null;
const turnstileSitekey =
  ARCHITECT.turnstileSitekey && !ARCHITECT.turnstileSitekey.includes("{{")
    ? ARCHITECT.turnstileSitekey
    : null;
---

{
  enabled && embedSrc && (
    <script
      is:inline
      src={embedSrc}
      data-agent-slug={ARCHITECT.agentSlug}
      data-public-key={ARCHITECT.publicKey}
      data-accent={ARCHITECT.accent}
      data-title={ARCHITECT.title}
      data-greeting={ARCHITECT.greeting}
      data-turnstile-sitekey={turnstileSitekey ?? undefined}
      async
    />
  )
}
