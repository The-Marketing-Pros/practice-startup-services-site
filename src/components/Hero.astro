---
import { SITE, ARCHITECT } from "@data/site";
import { CONSULT_BOOKING_URL, CONSULT_CTA_LABEL } from "@config/site";
import { phases } from "@data/phases";

const architectVisible =
  ARCHITECT.enabled &&
  ARCHITECT.appUrl &&
  !ARCHITECT.appUrl.includes("{{") &&
  ARCHITECT.publicKey &&
  !ARCHITECT.publicKey.includes("{{");
---

<section class="relative overflow-hidden border-b border-ink/8">
  <!-- Blueprint backdrop — minor + major drafting grid with brass crosshairs -->
  <div class="absolute inset-0 -z-10 text-ink" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="bp-grid-minor" x="0" y="0" width="24" height="24" patternUnits="userSpaceOnUse">
          <path d="M 24 0 L 0 0 0 24" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.03" />
        </pattern>
        <pattern id="bp-grid-major" x="0" y="0" width="96" height="96" patternUnits="userSpaceOnUse">
          <path d="M 96 0 L 0 0 0 96" fill="none" stroke="currentColor" stroke-width="1" opacity="0.05" />
          <path d="M 96 91 v10 M 91 96 h10" fill="none" stroke="hsl(var(--bronze-600))" stroke-width="1" opacity="0.25" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#bp-grid-minor)" />
      <rect width="100%" height="100%" fill="url(#bp-grid-major)" />
    </svg>
  </div>

  <div class="container-site pt-16 lg:pt-24 pb-0">
    <!-- Sheet annotation — drafting title strip -->
    <div class="hidden md:flex items-center justify-between phase-label text-graphite-500 mb-10" aria-hidden="true">
      <span>Sheet 01 · Independent practice blueprint</span>
      <span>Scale: one launch · Drawn in order</span>
    </div>

    <div class="grid lg:grid-cols-12 gap-12 items-center pb-14 lg:pb-16">
      <div class="lg:col-span-7">
        <div class="phase-label text-bronze-700 mb-6">
          <span class="inline-block h-px w-8 bg-bronze align-middle mr-3"></span>
          The Independent Practice Blueprint
        </div>

        <h1 class="font-display font-medium text-display-xl text-balance text-ink mb-6">
          The practice launch guide<span class="text-bronze">.</span>
          <span class="block text-graphite-700 font-normal">And the team to make it real.</span>
        </h1>

        <p class="text-lede text-graphite-700 max-w-narrow mb-8 text-pretty">
          {SITE.promise}
        </p>

        <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-x-5 gap-y-3">
          <a
            href={CONSULT_BOOKING_URL}
            target="_blank"
            rel="noopener"
            class="btn-primary"
          >
            {CONSULT_CTA_LABEL}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a
            href="/resources/startup-checklist/"
            class="group inline-flex items-center gap-1.5 text-small font-medium text-graphite-700 hover:text-ink transition-colors underline decoration-ink/20 hover:decoration-bronze decoration-1 underline-offset-4"
          >
            Or get the free startup checklist
            <span aria-hidden="true" class="text-bronze-700 transition-transform group-hover:translate-x-0.5">&rarr;</span>
          </a>
        </div>

        {architectVisible && (
          <button
            type="button"
            data-architect-open
            class="mt-6 inline-flex items-center gap-3 text-small text-graphite-700 hover:text-ink transition-colors group cursor-pointer text-left"
          >
            <span class="inline-flex items-center justify-center h-7 w-7 rounded-sharp bg-ink text-paper-100 font-display font-medium">
              A
            </span>
            <span>
              Or <span class="underline decoration-bronze decoration-2 underline-offset-2">ask The Architect</span> — the AI companion that knows the blueprint inside out. Free.
            </span>
          </button>
        )}
      </div>

      <div class="lg:col-span-5">
        <!-- Hero side card: an editorial annotation establishing voice -->
        <div class="card-blueprint relative">
          <!-- Drafting corner ticks -->
          <span class="absolute -top-px -left-px h-3 w-3 border-t-2 border-l-2 border-bronze/60" aria-hidden="true"></span>
          <span class="absolute -top-px -right-px h-3 w-3 border-t-2 border-r-2 border-bronze/60" aria-hidden="true"></span>
          <span class="absolute -bottom-px -left-px h-3 w-3 border-b-2 border-l-2 border-bronze/60" aria-hidden="true"></span>
          <span class="absolute -bottom-px -right-px h-3 w-3 border-b-2 border-r-2 border-bronze/60" aria-hidden="true"></span>

          <div class="phase-label text-bronze-700 mb-3">Operator's note</div>
          <p class="text-body text-graphite-800 mb-4 leading-relaxed">
            Most physicians launch private practices the way they were taught to do residency — show up,
            work hard, hope it works. That's how you lose 90–180 days of revenue to credentialing,
            burn working capital on the wrong EHR, and overpay for a marketing program that doesn't fit.
          </p>
          <p class="text-body text-ink leading-relaxed">
            We built this site to give you the order of operations — and the team to execute it.
          </p>
          <div class="mt-5 pt-5 border-t border-ink/8 flex items-center gap-3">
            <span class="phase-label text-graphite-600">From the team at</span>
            <span class="font-display text-base font-medium text-ink">Practice Startup Services</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Numbered phase ribbon — the blueprint's spine, drawn across the hero -->
  <nav class="relative border-t border-ink/8 bg-paper-50/70" aria-label="The seven launch phases">
    <div class="container-site py-5">
      <div class="phase-label text-graphite-600 mb-4 flex items-center gap-3">
        <span class="inline-block h-px w-6 bg-bronze rule-draw" aria-hidden="true"></span>
        The build sequence · seven phases, in order
      </div>
      <div class="relative">
        <span class="hidden sm:block absolute left-0 right-0 top-[1.05rem] h-px bg-ink/10 rule-draw" aria-hidden="true"></span>
        <ol class="grid grid-cols-4 sm:grid-cols-7 gap-x-2 gap-y-4 relative" role="list">
        {
          phases.map((p) => (
            <li class="relative">
              <a
                href={`/journey/${p.slug}/`}
                class="group flex flex-col gap-1.5 py-1 min-h-[44px]"
              >
                <span class="flex items-center gap-2">
                  <span class="relative z-10 inline-flex h-2 w-2 rounded-full border border-bronze bg-paper-50 group-hover:bg-bronze transition-colors" aria-hidden="true"></span>
                  <span class="font-mono text-small font-medium text-bronze-700 group-hover:text-bronze-900 transition-colors">{p.id}</span>
                </span>
                <span class="text-small font-medium text-graphite-700 group-hover:text-ink transition-colors leading-tight">
                  {p.verb}
                </span>
              </a>
            </li>
          ))
        }
        </ol>
      </div>
    </div>
  </nav>
</section>
