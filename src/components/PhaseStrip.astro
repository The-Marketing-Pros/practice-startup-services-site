---
// Compact phase navigation strip — used on phase pages + service pages
import { phases } from "@data/phases";
import type { PhaseId } from "@data/phases";

interface Props {
  current?: PhaseId;
  ariaLabel?: string;
}

const { current, ariaLabel = "Phase navigation" } = Astro.props;
---

<nav class="border-t border-b border-ink/8 bg-paper-50" aria-label={ariaLabel}>
  <div class="container-site py-3">
    <ol class="grid grid-cols-7 gap-1 sm:gap-2">
      {
        phases.map((p) => {
          const isCurrent = p.id === current;
          return (
            <li>
              <a
                href={`/journey/${p.slug}/`}
                aria-current={isCurrent ? "page" : undefined}
                class={`block text-center py-2 px-1 rounded-soft border transition-colors ${
                  isCurrent
                    ? "bg-ink text-paper-100 border-ink"
                    : "border-transparent hover:bg-paper-200/70 text-graphite-700 hover:text-ink"
                }`}
              >
                <div class={`font-mono text-label ${isCurrent ? "text-bronze-300" : "text-graphite-500"}`}>
                  {p.id}
                </div>
                <div class={`text-small font-medium leading-tight mt-0.5 hidden sm:block ${isCurrent ? "text-paper-100" : ""}`}>
                  {p.verb}
                </div>
              </a>
            </li>
          );
        })
      }
    </ol>
  </div>
</nav>
