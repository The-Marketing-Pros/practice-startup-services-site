---
// /scan — standalone Launch Readiness Scan landing page.
// Campaign-grade surface for the Control Room aesthetic.
// SEO target: 'practice startup quiz', 'practice readiness check', 'medical practice launch assessment'.
import BaseLayout from "@layouts/BaseLayout.astro";
import FinalCta from "@components/FinalCta.astro";
import { SITE } from "@data/site";
import { phases } from "@data/phases";
---

<BaseLayout
  title="Practice Launch Readiness Scan"
  description="Five questions. The exact phase you should focus on, the resources you need now, and the next decision in front of you. Free."
>
  <!-- Control Room hero -->
  <section class="bg-ink text-paper-100 py-16 lg:py-24 relative overflow-hidden border-b border-paper-200/10">
    <div class="absolute inset-0 opacity-30 -z-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-40 -right-40 h-[28rem] w-[28rem] rounded-full bg-signal/10 blur-3xl"></div>
      <div class="absolute -bottom-32 -left-32 h-[22rem] w-[22rem] rounded-full bg-bronze/10 blur-3xl"></div>
    </div>

    <div class="container-site relative">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <div class="phase-label text-signal mb-5">
            <span class="inline-flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-signal animate-pulse"></span>
              Control room · Launch readiness scan
            </span>
          </div>
          <h1 class="font-display text-display-xl font-medium text-paper-100 mb-5 text-balance">
            Where are you in the launch?
          </h1>
          <p class="text-lede text-paper-200/85 max-w-prose-wide text-pretty mb-6">
            Five questions. We'll route you to the exact phase you should focus on, the resources
            you need now, and the next decision in front of you.
          </p>
          <p class="text-small text-paper-200/65 font-mono">
            No signup. No spam. Just sequencing.
          </p>
        </div>

        <div class="lg:col-span-5">
          <form
            class="bg-paper-100 text-ink rounded-card p-6 lg:p-8 shadow-elevated"
            action="/scan/results/"
            method="get"
          >
            <fieldset class="space-y-5">
              <legend class="phase-label text-bronze-700 mb-2">Five quick questions</legend>

              <div>
                <label class="block text-small font-medium text-ink mb-2" for="scan-role-full">
                  I'm a…
                </label>
                <select
                  id="scan-role-full"
                  name="role"
                  class="w-full bg-paper-50 border border-ink/15 rounded-soft px-4 py-3 text-body focus:border-bronze focus:outline-none"
                >
                  <option value="">Choose your role</option>
                  <option value="md">Physician (MD/DO)</option>
                  <option value="np">Nurse Practitioner</option>
                  <option value="pa">Physician Assistant</option>
                  <option value="bh">Behavioral Health Provider</option>
                  <option value="admin">Practice Administrator</option>
                </select>
              </div>

              <div>
                <label class="block text-small font-medium text-ink mb-2" for="scan-stage-full">
                  Where am I now?
                </label>
                <select
                  id="scan-stage-full"
                  name="stage"
                  class="w-full bg-paper-50 border border-ink/15 rounded-soft px-4 py-3 text-body focus:border-bronze focus:outline-none"
                >
                  <option value="">Pick the closest match</option>
                  <option value="thinking">Thinking about it</option>
                  <option value="planning">Planning</option>
                  <option value="forming">Forming the business</option>
                  <option value="credentialing">In credentialing</option>
                  <option value="building">Building infrastructure</option>
                  <option value="launching">Launching marketing</option>
                  <option value="open">Open and growing</option>
                </select>
              </div>

              <div>
                <label class="block text-small font-medium text-ink mb-2" for="scan-timeline-full">
                  Target open date
                </label>
                <select
                  id="scan-timeline-full"
                  name="timeline"
                  class="w-full bg-paper-50 border border-ink/15 rounded-soft px-4 py-3 text-body focus:border-bronze focus:outline-none"
                >
                  <option value="">Choose a window</option>
                  <option value="3mo">Within 3 months</option>
                  <option value="6mo">3–6 months</option>
                  <option value="9mo">6–9 months</option>
                  <option value="12mo">9–12 months</option>
                  <option value="exploring">Just exploring</option>
                </select>
              </div>

              <div>
                <label class="block text-small font-medium text-ink mb-2" for="scan-biggest-full">
                  My biggest unknown right now is…
                </label>
                <select
                  id="scan-biggest-full"
                  name="unknown"
                  class="w-full bg-paper-50 border border-ink/15 rounded-soft px-4 py-3 text-body focus:border-bronze focus:outline-none"
                >
                  <option value="">Pick what matters most</option>
                  <option value="model">What practice model fits</option>
                  <option value="numbers">Whether the numbers work</option>
                  <option value="credentialing">Credentialing timing</option>
                  <option value="systems">EHR / billing / infrastructure</option>
                  <option value="marketing">How to find patients</option>
                  <option value="financing">How to finance the launch</option>
                  <option value="legal">Legal / entity setup</option>
                </select>
              </div>

              <div>
                <label class="block text-small font-medium text-ink mb-2" for="scan-state-full">
                  State (optional)
                </label>
                <input
                  type="text"
                  id="scan-state-full"
                  name="state"
                  placeholder="e.g. FL"
                  maxlength="32"
                  class="w-full bg-paper-50 border border-ink/15 rounded-soft px-4 py-3 text-body focus:border-bronze focus:outline-none"
                />
              </div>

              <input type="hidden" name="source" value="launch-readiness-scan" />

              <button type="submit" class="btn-primary w-full justify-center">
                Get my next steps
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>

              <p class="text-small text-graphite-600 text-center">
                Routes you to a phase guide + a consultation slot.
              </p>
            </fieldset>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- What the scan tells you -->
  <section class="border-b border-ink/8 py-16 lg:py-20">
    <div class="container-site">
      <div class="max-w-prose mx-auto">
        <h2 class="font-display text-display-md font-medium text-ink mb-5 text-balance">
          What the scan actually tells you.
        </h2>
        <p class="text-body text-graphite-800 leading-relaxed mb-4 text-pretty">
          We don't run a generic personality quiz. The scan maps your answers to the 7-phase
          blueprint, identifies the phase you should focus on right now, surfaces the watchouts
          most likely to bite you in your situation, and routes you to the resources we have
          for that phase.
        </p>
        <p class="text-body text-graphite-800 leading-relaxed mb-4 text-pretty">
          If your answers suggest you're about to make an expensive mistake — credentialing
          starting too late, picking a location before validating the payer mix, hiring before
          the workflow can absorb new providers — the scan tells you that directly.
        </p>
        <p class="text-body text-graphite-800 leading-relaxed text-pretty">
          And if it makes sense to talk to a human about your specific situation, the scan
          surfaces that too. The first consultation is free.
        </p>
      </div>
    </div>
  </section>

  <!-- The 7 phases at a glance -->
  <section class="border-b border-ink/8 py-16 lg:py-20 bg-paper-200/40">
    <div class="container-site">
      <div class="max-w-3xl mb-10">
        <div class="phase-label text-bronze-700 mb-3">For context</div>
        <h2 class="font-display text-display-lg font-medium text-ink mb-3 text-balance">
          The 7 phases the scan maps to.
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {
          phases.map((p) => (
            <a
              href={`/journey/${p.slug}`}
              class="card-blueprint hover:border-ink/25 transition-colors group flex flex-col"
            >
              <div class="flex items-center justify-between mb-3">
                <div class="font-mono text-display-sm text-bronze-700 font-medium leading-none">
                  {p.id}
                </div>
                {p.controlRoom && (
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-sharp bg-signal/15 text-signal-900 font-mono text-label">
                    <span class="h-1.5 w-1.5 rounded-full bg-signal"></span>
                    Control room
                  </span>
                )}
              </div>
              <div class="font-display text-base font-medium text-ink mb-2">
                {p.verb} · {p.title}
              </div>
              <p class="text-small text-graphite-700 text-pretty">{p.subtitle}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
