---
import BaseLayout from "@layouts/BaseLayout.astro";
import BuildCrews from "@components/BuildCrews.astro";
import FinalCta from "@components/FinalCta.astro";
---

<BaseLayout
  title="Services"
  description="Five build crews — practice startup consulting, credentialing, RCM, websites, and infrastructure. Hire what you need, when you need it."
>
  <section class="border-b border-ink/8 py-16 lg:py-24">
    <div class="container-site">
      <div class="max-w-3xl">
        <div class="phase-label text-bronze-700 mb-5">Build crews</div>
        <h1 class="font-display text-display-xl font-medium text-ink mb-5 text-balance">
          Services framed by the work, not the org chart.
        </h1>
        <p class="text-lede text-graphite-700 max-w-prose-wide text-pretty">
          Five crews. Each owns a phase of the launch. Each integrates with the others when you bring
          us on for more than one. You hire what you need, when you need it — and we stay coordinated
          with your other vendors so the build sequence holds.
        </p>
      </div>
    </div>
  </section>

  <BuildCrews />
  <FinalCta />
</BaseLayout>
