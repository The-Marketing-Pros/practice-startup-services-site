---
import BaseLayout from "@layouts/BaseLayout.astro";
import FinalCta from "@components/FinalCta.astro";
import { phases } from "@data/phases";
import { SITE } from "@data/site";
---

<BaseLayout
  title="The Practice Launch Checklist"
  description="Phase-ordered, opinionated, and free. The exact tasks for each of the 7 phases — with the watchouts most checklists skip."
>
  <section class="border-b border-ink/8 py-14 lg:py-20 relative overflow-hidden">
    <div class="absolute inset-0 -z-10 opacity-[0.04]" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="bp-grid-check" x="0" y="0" width="48" height="48" patternUnits="userSpaceOnUse">
            <path d="M 48 0 L 0 0 0 48" fill="none" stroke="#0E1F36" stroke-width="1" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#bp-grid-check)" />
      </svg>
    </div>

    <div class="container-site relative">
      <div class="max-w-3xl">
        <div class="phase-label text-bronze-700 mb-5">Free · No email gate</div>
        <h1 class="font-display text-display-xl font-medium text-ink mb-5 text-balance">
          The Practice Launch Checklist.
        </h1>
        <p class="text-lede text-graphite-700 max-w-prose-wide text-pretty mb-6">
          Phase-ordered, opinionated, and free. The exact tasks for each of the 7 phases — with the
          watchouts most checklists skip. Use it for free. Hire us when you want the build crew.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={SITE.scheduleUrl} class="btn-primary">
            {SITE.primaryCta}
          </a>
          <a href="/journey" class="btn-secondary">
            See the full journey
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-ink/8 py-16 lg:py-20">
    <div class="container-site">
      <ol class="space-y-12 max-w-prose-wide mx-auto">
        {
          phases.map((p) => (
            <li>
              <div class="flex items-start gap-5">
                <div class="font-mono text-display-md text-bronze-700 font-medium leading-none">
                  {p.id}
                </div>
                <div class="flex-1">
                  <div class="phase-label text-graphite-500 mb-1">Phase {p.id} · {p.verb}</div>
                  <h2 class="font-display text-display-md font-medium text-ink mb-2 text-balance">
                    {p.title}
                  </h2>
                  <p class="text-body text-graphite-800 leading-relaxed mb-5 text-pretty">
                    {p.subtitle}
                  </p>

                  <div class="phase-label text-graphite-600 mb-2">Must do first</div>
                  <p class="text-body text-ink leading-relaxed mb-5">{p.whatHappensFirst}</p>

                  <div class="phase-label text-graphite-600 mb-2">Can do in parallel</div>
                  <ul class="space-y-1.5 mb-5">
                    {p.whatCanHappenInParallel.map((item) => (
                      <li class="flex gap-3 text-body text-graphite-800 leading-relaxed">
                        <span class="font-mono text-bronze-700 mt-1">☐</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>

                  <div class="do-not-skip">
                    <div class="do-not-skip-label">Watchouts</div>
                    <ul class="space-y-1.5 mt-2">
                      {p.whatCommonlyDelays.map((item) => (
                        <li class="flex gap-3 text-body text-graphite-900 leading-relaxed">
                          <span class="text-warn font-mono mt-1">!</span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="mt-5 flex flex-wrap gap-3 text-small">
                    <a href={`/journey/${p.slug}`} class="text-bronze-700 hover:text-ink font-medium">
                      Full Phase {p.id} guide →
                    </a>
                    <span class="text-graphite-400">·</span>
                    <a href={p.freeResource.href} class="text-graphite-700 hover:text-ink">
                      {p.freeResource.label}
                    </a>
                  </div>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
