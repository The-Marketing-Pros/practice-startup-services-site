---
import BaseLayout from "@layouts/BaseLayout.astro";
import FinalCta from "@components/FinalCta.astro";
import PhaseStrip from "@components/PhaseStrip.astro";
import RelatedRoutes from "@components/RelatedRoutes.astro";
import { segments } from "@data/segments";
import { phases, phaseById } from "@data/phases";
import { services } from "@data/services";
import { SITE } from "@data/site";

export function getStaticPaths() {
  return segments.map((s) => ({ params: { slug: s.slug }, props: { segment: s } }));
}

const { segment } = Astro.props;
const focusPhases = segment.phasesOfFocus.map((id) => phaseById[id]);
const entryPhase = phaseById[segment.preferredEntryPhase];

// Surface the most relevant service for this segment based on its phases of focus
const topRelatedService =
  services.find((s) => segment.phasesOfFocus.includes(s.primaryPhase)) || services[0];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://practicestartupservices.com/" },
    { "@type": "ListItem", position: 2, name: "Who We Help", item: "https://practicestartupservices.com/who-we-help/" },
    { "@type": "ListItem", position: 3, name: segment.name, item: `https://practicestartupservices.com/who-we-help/${segment.slug}/` },
  ],
};
---

<BaseLayout title={`For ${segment.name}`} description={segment.sub} schema={breadcrumbSchema}>
  <section class="border-b border-ink/8 py-14 lg:py-20 relative overflow-hidden">
    <div class="absolute inset-0 -z-10 opacity-[0.04]" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id={`bp-grid-seg-${segment.slug}`} x="0" y="0" width="48" height="48" patternUnits="userSpaceOnUse">
            <path d="M 48 0 L 0 0 0 48" fill="none" stroke="#0E1F36" stroke-width="1" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill={`url(#bp-grid-seg-${segment.slug})`} />
      </svg>
    </div>

    <div class="container-site relative">
      <div class="flex flex-wrap items-center gap-3 phase-label text-graphite-600 mb-6">
        <a href="/who-we-help" class="hover:text-ink transition-colors">Who we help</a>
        <span aria-hidden="true">/</span>
        <span class="text-bronze-700">{segment.shortLabel}</span>
      </div>

      <div class="grid lg:grid-cols-12 gap-10 items-start">
        <div class="lg:col-span-8">
          <h1 class="font-display font-medium text-display-xl text-balance text-ink mb-5">
            {segment.headline}
          </h1>
          <p class="text-lede text-graphite-700 max-w-prose-wide mb-7 text-pretty">
            {segment.sub}
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={SITE.scheduleUrl} class="btn-primary">
              {SITE.primaryCta}
            </a>
            <a href={`/journey/${entryPhase.slug}`} class="btn-secondary">
              Start at Phase {entryPhase.id}: {entryPhase.title}
            </a>
          </div>
        </div>

        <aside class="lg:col-span-4 card-blueprint">
          <div class="phase-label text-graphite-500 mb-1">Highest-leverage phases</div>
          <div class="text-small text-graphite-700 mb-3">for {segment.shortLabel.toLowerCase()} — the full 7-phase journey applies</div>
          <ul class="space-y-2.5">
            {
              focusPhases.map((p) => (
                <li>
                  <a href={`/journey/${p.slug}`} class="group flex items-center gap-3">
                    <span class="font-mono text-label text-bronze-700">{p.id}</span>
                    <span class="text-small text-graphite-800 group-hover:text-ink transition-colors">
                      {p.title}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <PhaseStrip current={segment.preferredEntryPhase} ariaLabel={`Journey for ${segment.shortLabel}`} />

  <section class="border-b border-ink/8 py-16 lg:py-20">
    <div class="container-site">
      <div class="grid lg:grid-cols-12 gap-10">
        <div class="lg:col-span-7">
          <div class="phase-label text-bronze-700 mb-3">Why this segment is different</div>
          <h2 class="font-display text-display-lg font-medium text-ink mb-5 text-balance">
            What changes for {segment.shortLabel.toLowerCase()}.
          </h2>
          <p class="text-body text-graphite-800 leading-relaxed max-w-prose-wide text-pretty">
            {segment.whyThisIsDifferent}
          </p>
        </div>

        <aside class="lg:col-span-5">
          <div class="do-not-skip">
            <div class="do-not-skip-label">Segment-specific watchouts</div>
            <ul class="space-y-2.5 mt-3">
              {
                segment.specificWatchouts.map((w) => (
                  <li class="flex gap-3 text-body text-graphite-900 leading-relaxed">
                    <span class="text-warn font-mono mt-1">!</span>
                    <span>{w}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- All 7 phases at a glance — same depth as state/specialty pages -->
  <section class="border-b border-ink/8 py-16 lg:py-20 bg-paper-200/40">
    <div class="container-site">
      <div class="max-w-3xl mb-10">
        <div class="phase-label text-bronze-700 mb-3">The blueprint for {segment.shortLabel.toLowerCase()}</div>
        <h2 class="font-display text-display-lg font-medium text-ink mb-4 text-balance">
          The 7 phases apply. The details shift.
        </h2>
        <p class="text-body text-graphite-700 max-w-prose-wide text-pretty">
          The launch journey applies regardless of provider type, but the specifics in each phase
          shift depending on {segment.shortLabel.toLowerCase()}-specific scope of practice, payer
          dynamics, and credentialing tracks. Use the phase guides below for the foundation; layer
          the {segment.shortLabel.toLowerCase()}-specific watchouts above onto your build sequence.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {
          phases.map((p) => (
            <a
              href={`/journey/${p.slug}`}
              class="card-blueprint hover:border-ink/25 transition-colors group flex flex-col"
            >
              <div class="font-mono text-display-sm text-bronze-700 font-medium leading-none mb-2">
                {p.id}
              </div>
              <div class="font-display text-base font-medium text-ink mb-1">
                {p.verb} · {p.title}
              </div>
              <p class="text-small text-graphite-700 text-pretty">{p.subtitle}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Contextual cross-link: best-fit service for this segment -->
  {topRelatedService && (
    <section class="border-b border-ink/8 py-12 lg:py-16">
      <div class="container-site">
        <div class="max-w-prose-wide">
          <div class="phase-label text-bronze-700 mb-3">When you want help</div>
          <a
            href={`/services/${topRelatedService.slug}`}
            class="block p-6 rounded-soft border border-ink/8 hover:border-ink/25 hover:bg-paper-200/60 transition-colors group"
          >
            <div class="font-mono text-label uppercase tracking-[0.18em] text-bronze-700 mb-2">
              {topRelatedService.crewLabel}
            </div>
            <div class="font-display text-display-sm font-medium text-ink group-hover:text-bronze-700 transition-colors mb-2">
              {topRelatedService.name}
            </div>
            <p class="text-body text-graphite-700 leading-relaxed">
              {topRelatedService.outcomeSub}
            </p>
            <div class="mt-4 pt-4 border-t border-ink/8 text-small font-medium text-ink group-hover:text-bronze-700 transition-colors">
              See the crew →
            </div>
          </a>
        </div>
      </div>
    </section>
  )}

  <RelatedRoutes />
  <FinalCta variant="specialty" />
</BaseLayout>
