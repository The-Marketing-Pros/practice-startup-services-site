---
import BaseLayout from "@layouts/BaseLayout.astro";
import FinalCta from "@components/FinalCta.astro";
import { segments } from "@data/segments";
---

<BaseLayout
  title="Who We Help"
  description="Physicians, NPs, PAs, behavioral health providers, and specialty practices. Each segment has different watchouts. We adapt the launch sequence to yours."
>
  <section class="border-b border-ink/8 py-16 lg:py-24">
    <div class="container-site">
      <div class="grid lg:grid-cols-12 gap-8 items-end">
        <div class="lg:col-span-12">
          <div class="phase-label text-bronze-700 mb-5">Who we help</div>
          <h1 class="font-display text-display-xl font-medium text-ink mb-5">Different providers. Different watchouts. Same blueprint.</h1>
        </div>
        <div class="lg:col-span-12 max-w-prose-wide">
          <p class="text-lede text-graphite-700 text-pretty">
          The 7-phase launch journey applies to every independent provider. But the specifics — scope of practice,
          credentialing timelines, payer mix realities, equipment — shift depending on who's launching.
          Find your segment for the version that fits.
        </p>
      </div>
    </div>
  </section>

  <section class="border-b border-ink/8 py-16 lg:py-20 bg-paper-200/40">
    <div class="container-site">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          segments.map((s) => (
            <a
              href={`/who-we-help/${s.slug}`}
              class="card-blueprint hover:border-ink/25 transition-colors group flex flex-col"
            >
              <div class="phase-label text-graphite-500 mb-3">{s.shortLabel}</div>
              <h2 class="font-display text-display-sm font-medium text-ink mb-3 text-balance">
                {s.name}
              </h2>
              <p class="text-small text-graphite-700 text-pretty flex-1 mb-4">{s.sub}</p>
              <div class="mt-auto pt-4 border-t border-ink/8 flex items-center justify-between text-small font-medium text-ink group-hover:text-bronze-700 transition-colors">
                See the blueprint for {s.shortLabel}
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
