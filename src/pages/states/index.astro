---
import BaseLayout from "@layouts/BaseLayout.astro";
import FinalCta from "@components/FinalCta.astro";
import { states } from "@data/states";
---

<BaseLayout
  title="Practice Startup Guidance by State"
  description="State-specific practice startup guidance — credentialing timing, payer landscape, entity rules, and scope-of-practice variations that change the launch sequence."
>
  <section class="border-b border-ink/8 py-16 lg:py-24">
    <div class="container-site">
      <div class="grid lg:grid-cols-12 gap-8 items-end">
        <div class="lg:col-span-12">
          <div class="phase-label text-bronze-700 mb-5">By state</div>
          <h1 class="font-display text-display-xl font-medium text-ink mb-5">Different states. Different watchouts. Same blueprint.</h1>
        </div>
        <div class="lg:col-span-12 max-w-prose-wide">
          <p class="text-lede text-graphite-700 text-pretty">
          The 7-phase launch journey applies in every state. But the specific watchouts —
          credentialing timing, payer mix, entity rules, scope of practice — shift state to state.
          Find your state for the version that fits.
        </p>
      </div>
    </div>
  </section>

  <section class="border-b border-ink/8 py-16 lg:py-20 bg-paper-200/40">
    <div class="container-site">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-3">
        {
          states.map((s) => (
            <a
              href={`/states/${s.slug}`}
              class="card-blueprint hover:border-ink/25 transition-colors group flex flex-col"
            >
              <div class="flex items-baseline justify-between mb-2">
                <span class="font-mono text-display-sm font-medium text-bronze-700">{s.abbr}</span>
              </div>
              <div class="font-display text-base font-medium text-ink mb-1">{s.name}</div>
              <div class="text-small text-graphite-600 text-pretty">
                {s.major.slice(0, 2).join(", ")}
              </div>
            </a>
          ))
        }
      </div>
      <p class="text-small text-graphite-600 mt-6 max-w-prose-wide">
        More states are added as we expand coverage. If yours isn't listed yet, the 7-phase blueprint
        still applies — start there.
      </p>
    </div>
    </div>
  </section>

  <FinalCta />
</BaseLayout>
