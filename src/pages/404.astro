---
import BaseLayout from "@layouts/BaseLayout.astro";
import { phases } from "@data/phases";
---

<BaseLayout title="Not found" description="That page doesn't exist." noIndex={true}>
  <section class="py-24 lg:py-32 relative overflow-hidden">
    <div class="absolute inset-0 -z-10 opacity-[0.04]" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="bp-grid-404" x="0" y="0" width="48" height="48" patternUnits="userSpaceOnUse">
            <path d="M 48 0 L 0 0 0 48" fill="none" stroke="#0E1F36" stroke-width="1" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#bp-grid-404)" />
      </svg>
    </div>

    <div class="container-site relative">
      <div class="max-w-2xl mx-auto text-center">
        <div class="font-mono text-display-xl text-bronze-700 font-medium mb-4">404</div>
        <div class="phase-label text-graphite-600 mb-6">Off the blueprint</div>
        <h1 class="font-display text-display-lg font-medium text-ink mb-5 text-balance">
          We can't find that page.
        </h1>
        <p class="text-lede text-graphite-700 mb-10 text-pretty">
          That URL doesn't match anything in our launch blueprint. Try one of the seven phases below,
          or head to the homepage.
        </p>

        <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-2 mb-10">
          {
            phases.map((p) => (
              <a
                href={`/journey/${p.slug}`}
                class="border border-ink/10 hover:border-ink/30 hover:bg-paper-200/60 rounded-soft py-3 transition-colors"
              >
                <div class="font-mono text-label text-bronze-700">{p.id}</div>
                <div class="text-small text-graphite-800 mt-1">{p.verb}</div>
              </a>
            ))
          }
        </div>

        <a href="/" class="btn-primary">Back to the homepage</a>
      </div>
    </div>
  </section>
</BaseLayout>
