---
import "@/styles/global.css";
import SiteHeader from "@components/SiteHeader.astro";
import SiteFooter from "@components/SiteFooter.astro";
import Architect from "@components/Architect.astro";
import { SITE } from "@data/site";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  // When true, the title is used as-is without ' · Practice Startup Services' suffix
  // (used on the homepage where we want a head-term-loaded title without brand padding)
  titleAsIs?: boolean;
}

const { title, description, ogImage, noIndex = false, schema, titleAsIs = false } = Astro.props;
const pageTitle = (titleAsIs || title === SITE.name) ? title : `${title} · ${SITE.name}`;
const pageDescription = description ?? SITE.promise;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();

// Pick OG image: explicit prop > inferred from path > default home card
function pickOgImage(path: string, override?: string): string {
  if (override) return new URL(override, SITE.url).toString();
  if (path.startsWith("/journey/credentialing-enrollment")) return new URL("/og/og-credentialing.jpg", SITE.url).toString();
  if (path.startsWith("/journey")) return new URL("/og/og-journey.jpg", SITE.url).toString();
  if (path.startsWith("/scan")) return new URL("/og/og-journey.jpg", SITE.url).toString();
  return new URL("/og/og-home.jpg", SITE.url).toString();
}
const ogImageUrl = pickOgImage(Astro.url.pathname, ogImage);

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: SITE.name,
  url: SITE.url,
  description: SITE.promise,
  slogan: SITE.tagline,
  areaServed: { "@type": "Country", name: "United States" },
  serviceType: [
    "Practice Startup Consulting",
    "Medical Credentialing",
    "Revenue Cycle Management",
    "Medical Practice Website Design",
    "Practice Infrastructure Support",
  ],
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  isPartOf: { "@type": "WebSite", name: SITE.name, url: SITE.url },
};

const schemas = [orgSchema, webPageSchema, ...(Array.isArray(schema) ? schema : schema ? [schema] : [])];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />

    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <!-- OG / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <!-- Theme color (blueprint navy) -->
    <meta name="theme-color" content="#0E1F36" />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16.png" sizes="16x16" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Structured data -->
    {
      schemas.map((s) => (
        <script type="application/ld+json" set:html={JSON.stringify(s)} />
      ))
    }
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-ink focus:text-paper-100 focus:px-4 focus:py-2 focus:rounded-soft"
    >
      Skip to content
    </a>

    <SiteHeader />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <SiteFooter />

    <Architect />
  </body>
</html>
